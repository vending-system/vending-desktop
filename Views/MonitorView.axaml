<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VendingSystemClient.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
             x:Class="VendingSystemClient.Views.MonitorView"
             x:DataType="vm:MonitorViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI, Arial, sans-serif"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="FontFamily" Value="Segoe UI, Arial, sans-serif"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.StateCircle">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="13"/>
            <Setter Property="Margin" Value="2,0"/>
        </Style>
        <Style Selector="Button.StateCircle.Active">
            <Setter Property="BorderBrush" Value="#333"/>
        </Style>

        <Style Selector="Button.TagBtn">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#cccccc"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="2,0"/>
        </Style>
        <Style Selector="Button.TagBtn.Active">
            <Setter Property="Background" Value="#E3F2FD"/>
            <Setter Property="BorderBrush" Value="#2196F3"/>
            <Setter Property="Foreground" Value="#1565C0"/>
        </Style>

        <Style Selector="Button.ExtraBtn">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#ddd"/>
            <Setter Property="Background" Value="#f5f5f5"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Margin" Value="2,0"/>
        </Style>
        <Style Selector="Button.ExtraBtn.Active">
            <Setter Property="Background" Value="#FFF8E1"/>
            <Setter Property="BorderBrush" Value="#FFA000"/>
        </Style>

        <Style Selector="TextBlock.ColHdr">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="Button.RowIconBtn">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="1,0"/>
        </Style>
    </UserControl.Styles>

    <DockPanel Background="#f0f2f5">

        <Border DockPanel.Dock="Top" Background="White"
                Padding="16,10" BorderBrush="#e0e0e0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="BtnBack" Background="Transparent" BorderThickness="0"
                        Padding="6,4" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="←" FontSize="16" Foreground="#555"/>
                        <TextBlock Text="Назад" FontSize="14" Foreground="#555"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="Монитор ТА" FontSize="15" Foreground="#222"
                           FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="White"
                Padding="16,9" BorderBrush="#e0e0e0" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding TotalSummary}"
                           FontSize="13" Foreground="#444" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding StatusBarText}"
                           FontSize="12" Foreground="#999" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <DockPanel>

            <Border DockPanel.Dock="Top" Background="White"
                    Padding="14,10" BorderBrush="#e0e0e0" BorderThickness="0,0,0,1">
                <WrapPanel Orientation="Horizontal">

                    <StackPanel Orientation="Horizontal" Spacing="4"
                                VerticalAlignment="Center" Margin="0,0,12,4">
                        <TextBlock Text="Общее состояние" FontSize="12" Foreground="#666"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Button x:Name="BtnStateAll"  Classes="StateCircle" Classes.Active="{Binding FilterAll}"
                                Background="#9E9E9E" ToolTip.Tip="Все">
                            <TextBlock Text="✓" FontSize="10" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="BtnStateOk"   Classes="StateCircle" Classes.Active="{Binding FilterOk}"
                                Background="#4CAF50" ToolTip.Tip="Работает"/>
                        <Button x:Name="BtnStateError" Classes="StateCircle" Classes.Active="{Binding FilterError}"
                                Background="#f44336" ToolTip.Tip="Не работает"/>
                        <Button x:Name="BtnStateMaint" Classes="StateCircle" Classes.Active="{Binding FilterMaintenance}"
                                Background="#2196F3" ToolTip.Tip="На обслуживании"/>
                    </StackPanel>

                    <Border Width="1" Height="26" Background="#ddd" Margin="0,0,12,4" VerticalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal" Spacing="4"
                                VerticalAlignment="Center" Margin="0,0,12,4">
                        <TextBlock Text="Подключение" FontSize="12" Foreground="#666"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Button x:Name="BtnMdb" Classes="TagBtn" Classes.Active="{Binding FilterMdb}" Content="MDB"/>
                        <Button x:Name="BtnExe" Classes="TagBtn" Classes.Active="{Binding FilterExe}" Content="EXE"/>
                        <Button x:Name="BtnRh"  Classes="TagBtn" Classes.Active="{Binding FilterRh}"  Content="РН"/>
                        <Button x:Name="BtnSt"  Classes="TagBtn" Classes.Active="{Binding FilterSt}"  Content="ST"/>
                    </StackPanel>

                    <Border Width="1" Height="26" Background="#ddd" Margin="0,0,12,4" VerticalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal" Spacing="4"
                                VerticalAlignment="Center" Margin="0,0,12,4">
                        <TextBlock Text="Доп.статусы" FontSize="12" Foreground="#666"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Button x:Name="BtnExMoney"   Classes="ExtraBtn" Classes.Active="{Binding FilterMoney}"   ToolTip.Tip="Деньги заканчиваются">
                            <TextBlock Text="💰" Foreground="Black"  FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="BtnExWarn" Foreground="Black"    Classes="ExtraBtn" Classes.Active="{Binding FilterWarning}" ToolTip.Tip="Предупреждения">
                            <TextBlock Text="⚠" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="BtnExService"  Foreground="Black" Classes="ExtraBtn" Classes.Active="{Binding FilterService}" ToolTip.Tip="Нужно обслуживание">
                            <TextBlock Text="🔧" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="BtnExDocs"  Foreground="Black"   Classes="ExtraBtn" Classes.Active="{Binding FilterDocs}"    ToolTip.Tip="Документы">
                            <TextBlock Text="📋" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="BtnExPower" Foreground="Black"   Classes="ExtraBtn" Classes.Active="{Binding FilterPower}"   ToolTip.Tip="Проблема питания">
                            <TextBlock Text="🔌" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="BtnExCrit"  Foreground="Black"   Classes="ExtraBtn" Classes.Active="{Binding FilterCritical}" ToolTip.Tip="Критическая ошибка">
                            <TextBlock Text="❌" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="BtnExNoSig"  Foreground="Black"  Classes="ExtraBtn" Classes.Active="{Binding FilterNoSignal}" ToolTip.Tip="Нет связи">
                            <TextBlock Text="🔴" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>

                    <Border Width="1" Height="26" Background="#ddd" Margin="0,0,12,4" VerticalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal" Spacing="8"
                                VerticalAlignment="Center" Margin="0,0,0,4">
                        <TextBlock Text="Сортировка" FontSize="12" Foreground="#666" VerticalAlignment="Center"/>
                        <ComboBox SelectedItem="{Binding SelectedSort}"
                                  ItemsSource="{Binding SortOptions}"
                                  Width="185" Height="30" FontSize="12"/>
                        <Button Content="Применить"
                                Command="{Binding ApplyFiltersCommand}"
                                Background="#2196F3" Foreground="White"
                                Padding="16,6" CornerRadius="4" BorderThickness="0" FontSize="12"/>
                        <Button Content="Очистить"
                                Command="{Binding ClearFiltersCommand}"
                                Background="White" Foreground="#555"
                                Padding="16,6" CornerRadius="4"
                                BorderThickness="1" BorderBrush="#ccc" FontSize="12"/>
                    </StackPanel>

                </WrapPanel>
            </Border>

            <DockPanel>

                <Border DockPanel.Dock="Top" Background="#f5f6fa"
                        Padding="16,6" BorderBrush="#e0e0e0" BorderThickness="0,0,0,1">
                    <TextBlock Text="380649 — «ООО Торговые Автоматы»"
                               FontSize="13" FontWeight="SemiBold" Foreground="#333"/>
                </Border>

                <Grid DockPanel.Dock="Top"
                      ColumnDefinitions="50,3*,130,165,195,210,190,200,80"
                      Background="#f8f9fa" Height="38">
                    <Border Grid.ColumnSpan="9" BorderBrush="#e0e0e0" BorderThickness="0,0,0,1"/>
                    <TextBlock Grid.Column="0" Text="#"                 Classes="ColHdr" Margin="14,0,0,0"/>
                    <TextBlock Grid.Column="1" Text="Торговый автомат"  Classes="ColHdr" Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="Связь"             Classes="ColHdr" Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="3" Text="Загрузка"          Classes="ColHdr" Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="4" Text="Денежные средства" Classes="ColHdr" Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="5" Text="События"           Classes="ColHdr" Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="6" Text="Оборудование"      Classes="ColHdr" Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="7" Text="Информация"        Classes="ColHdr" Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="8" Text="Доп."              Classes="ColHdr" Margin="8,0,0,0"/>
                </Grid>

                <Border DockPanel.Dock="Top" Background="White" Padding="0,50" IsVisible="{Binding IsEmpty}">
                    <StackPanel HorizontalAlignment="Center" Spacing="12">
                        <TextBlock Text="🔍" FontSize="38" HorizontalAlignment="Center"/>
                        <TextBlock Text="Автоматы не найдены"
                                   FontSize="16" FontWeight="SemiBold" Foreground="#555"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Измените условия фильтрации"
                                   FontSize="13" Foreground="#999" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Top" Background="White" Padding="0,50" IsVisible="{Binding IsLoading}">
                    <StackPanel HorizontalAlignment="Center" Spacing="14">
                        <TextBlock Text="⏳" FontSize="32" HorizontalAlignment="Center"/>
                        <TextBlock Text="Загрузка данных..."
                                   FontSize="14" Foreground="#777" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Rows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:MonitorMachineRow">
                                <Grid ColumnDefinitions="50,3*,130,165,195,210,190,200,80"
                                      Background="{Binding StatusColor}" MinHeight="82">

                                    <Border Grid.ColumnSpan="9" BorderBrush="#e8e8e8"
                                            BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center"
                                                HorizontalAlignment="Center" Spacing="3">
                                        <Ellipse Width="10" Height="10" HorizontalAlignment="Center"
                                                 Fill="{Binding StatusId,
                                                   Converter={x:Static vm:StatusColorConverter.Instance}}"/>
                                        <TextBlock Text="{Binding Id}" FontSize="11" Foreground="#888"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,10">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="13" FontWeight="SemiBold" Foreground="#1a1a2e"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding ModelName}"
                                                   FontSize="11" Foreground="#777"
                                                   TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                        <TextBlock Text="{Binding Address}"
                                                   FontSize="11" Foreground="#999"
                                                   TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                                        <TextBlock Text="{Binding CompanyName}"
                                                   FontSize="10" Foreground="#bbb"
                                                   TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0" Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock FontSize="13" VerticalAlignment="Center"
                                                       Text="{Binding ConnectionStatus,
                                                         Converter={x:Static vm:ConnectionIconConverter.Instance}}"/>
                                            <TextBlock Text="{Binding ConnectionLabel}"
                                                       FontSize="12" FontWeight="SemiBold" Foreground="#222"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Bottom">
                                            <Border Width="4" Height="6"  CornerRadius="1"
                                                    Background="{Binding SignalStrength,
                                                      Converter={x:Static vm:SignalBarConverter.Instance},
                                                      ConverterParameter=1}"/>
                                            <Border Width="4" Height="9"  CornerRadius="1"
                                                    Background="{Binding SignalStrength,
                                                      Converter={x:Static vm:SignalBarConverter.Instance},
                                                      ConverterParameter=35}"/>
                                            <Border Width="4" Height="12" CornerRadius="1"
                                                    Background="{Binding SignalStrength,
                                                      Converter={x:Static vm:SignalBarConverter.Instance},
                                                      ConverterParameter=60}"/>
                                            <Border Width="4" Height="15" CornerRadius="1"
                                                    Background="{Binding SignalStrength,
                                                      Converter={x:Static vm:SignalBarConverter.Instance},
                                                      ConverterParameter=85}"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding LastSeenText}" FontSize="11" Foreground="#888"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="10,0" Spacing="4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Border Grid.Column="0" Height="12" CornerRadius="3"
                                                    Background="#e0e0e0" ClipToBounds="True" Margin="0,0,6,0">
                                                <Border HorizontalAlignment="Left" Height="12" CornerRadius="3"
                                                        Width="{Binding LoadPercent,
                                                          Converter={x:Static vm:PercentToWidthConverter.Instance}}"
                                                        Background="{Binding LoadPercent,
                                                          Converter={x:Static vm:LoadColorConverter.Instance}}"/>
                                            </Border>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding LoadPercent, StringFormat='{}{0}%'}"
                                                       FontSize="12" FontWeight="SemiBold" Foreground="#333"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <Border Background="#E8F5E9" CornerRadius="3" Padding="5,2">
                                                <TextBlock Text="общая" FontSize="10" Foreground="#388E3C"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding LoadTime}" FontSize="11" Foreground="#aaa"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="10,0" Spacing="4">
                                        <TextBlock Text="{Binding CashText}"
                                                   FontSize="14" FontWeight="Bold" Foreground="#1565C0"/>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="🪙" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding CoinsText}" FontSize="11" Foreground="#666"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Border CornerRadius="3" Padding="5,2" HorizontalAlignment="Left"
                                                Background="{Binding ChangeAvailable,
                                                  Converter={x:Static vm:BoolToBgConverter.Instance}}"
                                                BorderThickness="1"
                                                BorderBrush="{Binding ChangeAvailable,
                                                  Converter={x:Static vm:BoolToBorderConverter.Instance}}">
                                            <TextBlock Text="{Binding CashChangeText}" FontSize="10"
                                                       Foreground="{Binding ChangeAvailable,
                                                         Converter={x:Static vm:BoolToTextConverter.Instance}}"/>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="5" VerticalAlignment="Center" Margin="10,0" Spacing="5">
                                        <StackPanel IsVisible="{Binding Event1,
                                                      Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <TextBlock Text="{Binding Event1Time}" FontSize="10" Foreground="#bbb"/>
                                            <TextBlock Text="{Binding Event1}" FontSize="12" Foreground="#333"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <StackPanel IsVisible="{Binding Event2,
                                                      Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <TextBlock Text="{Binding Event2Time}" FontSize="10" Foreground="#bbb"/>
                                            <TextBlock Text="{Binding Event2}" FontSize="12" Foreground="#555"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <TextBlock IsVisible="{Binding Event1,
                                                     Converter={x:Static StringConverters.IsNullOrEmpty}}"
                                                   Text="—" FontSize="12" Foreground="#ccc"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="6" VerticalAlignment="Center" Margin="10,0" Spacing="5">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <Border CornerRadius="3" Padding="7,3"
                                                    Background="{Binding HasMdb, Converter={x:Static vm:BoolToBgConverter.Instance}}"
                                                    BorderThickness="1"
                                                    BorderBrush="{Binding HasMdb, Converter={x:Static vm:BoolToBorderConverter.Instance}}">
                                                <TextBlock Text="MDB" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{Binding HasMdb, Converter={x:Static vm:BoolToTextConverter.Instance}}"/>
                                            </Border>
                                            <Border CornerRadius="3" Padding="7,3"
                                                    Background="{Binding HasExe, Converter={x:Static vm:BoolToBgConverter.Instance}}"
                                                    BorderThickness="1"
                                                    BorderBrush="{Binding HasExe, Converter={x:Static vm:BoolToBorderConverter.Instance}}">
                                                <TextBlock Text="EXE" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{Binding HasExe, Converter={x:Static vm:BoolToTextConverter.Instance}}"/>
                                            </Border>
                                            <Border CornerRadius="3" Padding="5,3"
                                                    Background="#FFEBEE" BorderThickness="1" BorderBrush="#EF9A9A"
                                                    IsVisible="{Binding EquipmentError}">
                                                <TextBlock Text="⚠" FontSize="11" Foreground="#c62828"/>
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <Border CornerRadius="3" Padding="5,2"
                                                    Background="#E8F5E9" BorderThickness="1" BorderBrush="#A5D6A7">
                                                <TextBlock Text="🔌" FontSize="11"/>
                                            </Border>
                                            <Border CornerRadius="3" Padding="5,2"
                                                    Background="#E3F2FD" BorderThickness="1" BorderBrush="#90CAF9"
                                                    IsVisible="{Binding HasTerminal}">
                                                <TextBlock Text="💳" FontSize="11"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="7" VerticalAlignment="Center" Margin="10,0" Spacing="5">
                                        <TextBlock Text="{Binding InfoText}"
                                                   FontSize="12" Foreground="#444"
                                                   TextWrapping="Wrap" MaxWidth="185"/>
                                        <StackPanel Orientation="Horizontal" Spacing="2">
                                            <Button Classes="RowIconBtn" ToolTip.Tip="Настройки">
                                                <TextBlock Text="⚙" FontSize="14" Foreground="#aaa"/>
                                            </Button>
                                            <Button Classes="RowIconBtn" ToolTip.Tip="Документы">
                                                <TextBlock Text="📋" FontSize="14" Foreground="#aaa"/>
                                            </Button>
                                            <Button Classes="RowIconBtn" ToolTip.Tip="Связь">
                                                <TextBlock Text="📡" FontSize="14" Foreground="#aaa"/>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="8" VerticalAlignment="Center"
                                                HorizontalAlignment="Center" Margin="4,0" Spacing="4">
                                        <TextBlock Text="{Binding CountersText}" FontSize="11" Foreground="#555"
                                                   HorizontalAlignment="Center"/>
                                        <Button Classes="RowIconBtn" HorizontalAlignment="Center"
                                                ToolTip.Tip="Подробно">
                                            <TextBlock Text="≡" FontSize="18" Foreground="#2196F3"/>
                                        </Button>
                                    </StackPanel>

                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </DockPanel>
        </DockPanel>
    </DockPanel>
</UserControl>
